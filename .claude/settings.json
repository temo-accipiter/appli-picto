{
  "model": "sonnet",
  "outputStyle": "appli-picto-guide",

  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/session-context.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git commit:*|git push:*)",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/pre-commit.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/protect-generated-files.sh"
          }
        ]
      },
      {
        "matcher": "Edit(*.scss)",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/check-hardcoded-scss.sh"
          }
        ]
      },
      {
        "matcher": "Write(src/hooks/*.ts)",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/check-supabase-hooks.sh"
          }
        ]
      },
      {
        "matcher": "Bash(yarn *|npm *)",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/block-yarn-npm.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__supabase__apply_migration",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/post-migration.sh"
          }
        ]
      }
    ]
  }
}
