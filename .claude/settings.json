{
  "model": "sonnet",
  "outputStyle": "appli-picto-guide",

  "env": {
    "MAX_THINKING_TOKENS": "20000"
  },

  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/session-context.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git commit:*|git push:*)",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/pre-commit.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/protect-generated-files.sh"
          }
        ]
      },
      {
        "matcher": "Write(src/hooks/*.ts)",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/check-supabase-hooks.sh"
          }
        ]
      },
      {
        "matcher": "Bash(yarn *|npm *)",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/block-yarn-npm.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/suggest-compact.sh"
          }
        ],
        "description": "Suggère /compact tous les 15 éditions (optimisation contexte)"
      },
      {
        "matcher": "Write(*.md)",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/doc-file-warning.sh"
          }
        ],
        "description": "Avertit si création .md hors répertoires standards"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit(*.scss)",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/check-hardcoded-scss.sh"
          }
        ],
        "description": "Vérification valeurs hardcodées SCSS après édition (avertissement advisory)"
      },
      {
        "matcher": "mcp__supabase__apply_migration",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/post-migration.sh"
          }
        ]
      }
    ]
  }
}
